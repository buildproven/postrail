# =============================================================================
# PostRail Environment Configuration
# =============================================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.local.example .env.local
# 2. Fill in required values (marked with *REQUIRED*)
# 3. Generate encryption key: npx tsx scripts/generate-encryption-key.ts
# 4. Never commit .env.local to Git (it's in .gitignore)
#
# VALIDATION:
# - Environment validation runs automatically on startup
# - See lib/env-validator.ts for validation rules
# - Missing required vars will cause startup to fail with clear error messages
#
# =============================================================================
# DATABASE & AUTHENTICATION (REQUIRED)
# =============================================================================
#
# Supabase Configuration
# Get these from: https://app.supabase.com/projects/[your-project]/settings/api
#
# *REQUIRED* - Your Supabase project URL
# Format: https://[project-id].supabase.co
# Validation: Must be valid HTTPS URL containing "supabase"
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# *REQUIRED* - Supabase anonymous/public API key
# Location: Supabase Dashboard → Project Settings → API → anon/public key
# Validation: Must be >100 characters
# Security: Safe for client-side use (respects Row Level Security policies)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# =============================================================================
# AI GENERATION (REQUIRED)
# =============================================================================
#
# Anthropic Claude API
# Get your API key from: https://console.anthropic.com/
#
# *REQUIRED* - Claude API key for AI post generation
# Format: Must start with "sk-ant-"
# Validation: Must be >50 characters
# Usage: Generate social media posts from newsletter content
# Cost: ~$0.01-0.05 per newsletter (6 posts generated)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# OPTIONAL - Specify Claude model version
# Default: claude-sonnet-4-20250514
# Options: claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-3-5-20241022
# Note: Different models have different cost/speed/quality tradeoffs
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# =============================================================================
# SECURITY - ENCRYPTION (REQUIRED)
# =============================================================================
#
# Encryption Key for Platform Credentials
# Used to encrypt Twitter/LinkedIn/Facebook OAuth tokens before storing in database
#
# *REQUIRED* - AES-256 encryption key (64 hex characters = 32 bytes)
# Generate: npx tsx scripts/generate-encryption-key.ts
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Format: Exactly 64 hexadecimal characters (0-9, a-f)
# Validation: Must match /^[0-9a-fA-F]{64}$/
# Security: NEVER commit this to Git! Rotate if compromised.
ENCRYPTION_KEY=your-64-character-hex-key-here

# =============================================================================
# SECURITY - RATE LIMITING & MONITORING (OPTIONAL)
# =============================================================================
#
# Rate Limiting Mode
# Controls how rate limiting is enforced across server instances
#
# Options:
#   - "auto" (default): Use Redis if configured, otherwise fall back to memory
#   - "redis": Force distributed rate limiting (requires Upstash Redis config below)
#   - "memory": Per-instance rate limiting (NOT recommended for production)
#   - "disabled": Disable rate limiting (development only, NEVER use in production)
#
# Default: auto
# Production: Use "redis" with Upstash configuration
RATE_LIMIT_MODE=auto

# Enable Status Endpoints
# Allows users to check their own rate limit status via /api/rate-limit-status
# and SSRF protection statistics via /api/ssrf-status
#
# Default: false (disabled)
# Options: true, false
# Security: Safe to enable - users can only see their own data
ENABLE_STATUS_ENDPOINTS=false

# Enable Monitoring Endpoint
# Enables /api/monitoring endpoint with system health, security events, and logs
#
# Default: false (disabled)
# Options: true, false
# Security: Admin-only endpoint - only enable if you need system monitoring
# Note: Contains sensitive operational data, protect with authentication
ENABLE_MONITORING_ENDPOINT=false

# Trust Proxy Headers
# Enable if running behind reverse proxy (Vercel, Cloudflare, Railway, Render)
#
# Default: false
# Options: true, false
# When to enable: Behind Vercel, Cloudflare, or other reverse proxies
# Security: Only enable if you trust the proxy to set X-Forwarded-For correctly
# Risk: Attackers can spoof IP addresses if proxy isn't configured properly
NEXT_TRUST_PROXY=false

# =============================================================================
# OBSERVABILITY (OPTIONAL)
# =============================================================================
#
# Sentry Error Monitoring
# - NEXT_PUBLIC_SENTRY_DSN is required to capture browser errors
# - SENTRY_DSN is required to capture server errors (API routes, server actions)
# - SENTRY_AUTH_TOKEN is required at build time for source map uploads
#
# Where to get: https://sentry.io/ > Projects > Settings
#
# SENTRY_DSN=https://public-key.ingest.us.sentry.io/project-id
# NEXT_PUBLIC_SENTRY_DSN=https://public-key.ingest.us.sentry.io/project-id
# SENTRY_ENVIRONMENT=development
# SENTRY_AUTH_TOKEN=sentry-auth-token-with-org:project:release
# SENTRY_ORG=your-sentry-org-slug
# SENTRY_PROJECT=postrail

# =============================================================================
# REDIS & QUEUE SYSTEM (OPTIONAL - Future Feature)
# =============================================================================
#
# Upstash Redis Configuration
# Required for distributed rate limiting across multiple server instances
# Get these from: https://console.upstash.com/
#
# When to use:
#   - Production deployments with multiple instances
#   - Distributed rate limiting across servers
#   - Shared deduplication cache
#
# Local development: Leave empty to use in-memory fallback
# Production: Configure for distributed rate limiting
#
# UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token-here

# Upstash QStash Configuration (Post Scheduling)
# Used for automated post scheduling and background job processing
# Get these from: https://console.upstash.com/qstash
#
# Purpose: Schedule social media posts for future delivery
#
# QSTASH_URL=https://qstash.upstash.io
# QSTASH_TOKEN=your-qstash-token-here
# QSTASH_CURRENT_SIGNING_KEY=your-signing-key
# QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# =============================================================================
# OAUTH CREDENTIALS (REQUIRED for 1-click social connect)
# =============================================================================
#
# Application URL (REQUIRED for OAuth callbacks)
# Set to your app's public URL - used for OAuth redirect URIs
#
# Local development: http://localhost:3000
# Production: https://your-domain.com (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Twitter/X OAuth 2.0 Configuration
# For 1-click X posting to your account
# Get from: https://developer.twitter.com/en/portal/dashboard
#
# Setup steps:
# 1. Create project at Twitter Developer Portal
# 2. Create an App inside the project
# 3. Set up OAuth 2.0 (User authentication settings):
#    - App permissions: Read and write
#    - Type of app: Web App
#    - Redirect URI: {NEXT_PUBLIC_APP_URL}/api/platforms/twitter/callback
#    - Website URL: {NEXT_PUBLIC_APP_URL}
# 4. Get Client ID and Client Secret from Keys and Tokens tab
#
# Required scopes: tweet.read, tweet.write, users.read, offline.access
# Access Level: Free tier allows 500 posts/month
#
TWITTER_CLIENT_ID=your-twitter-client-id
TWITTER_CLIENT_SECRET=your-twitter-client-secret

# -----------------------------------------------------------------------------
# LinkedIn OAuth Configuration
# For 1-click LinkedIn posting to profiles and Company Pages
# Get from: https://www.linkedin.com/developers/apps
#
# Setup steps:
# 1. Create app at LinkedIn Developer Portal
# 2. Verify app with your Company Page
# 3. Add products: "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# 4. Add redirect URI: {NEXT_PUBLIC_APP_URL}/api/platforms/linkedin/callback
#
# Required scopes: openid, profile, email, w_member_social, w_organization_social
# Token expiry: 60 days (users will need to reconnect)
#
LINKEDIN_CLIENT_ID=your-linkedin-client-id
LINKEDIN_CLIENT_SECRET=your-linkedin-client-secret

# -----------------------------------------------------------------------------
# Facebook/Meta OAuth Configuration
# For 1-click Facebook Page posting
# Get from: https://developers.facebook.com/apps
#
# Setup steps:
# 1. Create app at Meta for Developers (select "Business" type)
# 2. Add product: "Facebook Login for Business"
# 3. Add redirect URI: {NEXT_PUBLIC_APP_URL}/api/platforms/facebook/callback
# 4. Request permissions: pages_show_list, pages_read_engagement, pages_manage_posts
#
# Note: App must be in "Live" mode for production use
# Token expiry: ~60 days for long-lived tokens (auto-converted from short-lived)
#
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# =============================================================================
# DEVELOPMENT & DEPLOYMENT
# =============================================================================
#
# Node Environment
# Set automatically by Next.js and deployment platforms
# Options: development, production, test
#
# NODE_ENV=development

# =============================================================================
# COMMON ISSUES & TROUBLESHOOTING
# =============================================================================
#
# Issue: "ANTHROPIC_API_KEY is required but not set"
# Fix: Add your API key from https://console.anthropic.com/
#
# Issue: "ENCRYPTION_KEY must be 64 hex characters"
# Fix: Run: npx tsx scripts/generate-encryption-key.ts
#
# Issue: "NEXT_PUBLIC_SUPABASE_URL is invalid"
# Fix: Ensure URL starts with https:// and contains "supabase"
#
# Issue: "Rate limiting not working in production"
# Fix: Set RATE_LIMIT_MODE=redis and configure UPSTASH_REDIS_* vars
#
# Issue: "Module not found" errors
# Fix: Run: npm install (requires Node 20+, see .npmrc)
#
# =============================================================================
# SECURITY REMINDERS
# =============================================================================
#
# ✅ DO:
#   - Keep .env.local in .gitignore (already configured)
#   - Use different encryption keys for dev/staging/production
#   - Rotate API keys regularly (quarterly recommended)
#   - Use environment variables on deployment platforms (Vercel/Railway/Render)
#   - Enable Redis rate limiting in production (RATE_LIMIT_MODE=redis)
#
# ❌ DON'T:
#   - Commit .env.local to Git (contains secrets)
#   - Share encryption keys via Slack/email (use 1Password/LastPass)
#   - Use production keys in development
#   - Disable rate limiting in production (RATE_LIMIT_MODE=disabled)
#   - Enable NEXT_TRUST_PROXY unless behind verified reverse proxy
#
# =============================================================================
# SERVICE AUTHENTICATION (OPTIONAL - FOR SERVICE INTEGRATIONS)
# =============================================================================
#
# Service API Keys for external service integrations
# Used for service-to-service communication (e.g., automation agents)
#
# To generate a service key:
#   node -e "const crypto = require('crypto'); const key = 'pr_sk_' + crypto.randomBytes(24).toString('base64url'); console.log('Key:', key); console.log('Hash:', crypto.createHash('sha256').update(key).digest('hex'));"
#
# Store the KEY in the external service's environment
# Store the HASH in PostRail's service_keys table
#
# Example: For an external marketing automation service
# EXTERNAL_SERVICE_KEY_HASH=<sha256-hash-of-service-key>

