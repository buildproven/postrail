# PostRail Test Environment Variables
# Copy to .env.test for running tests

# =============================================================================
# Test Database (use separate Supabase project for tests)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321  # Local Supabase
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon-key
SUPABASE_SERVICE_ROLE_KEY=test-service-role-key

# =============================================================================
# Test AI (use test API key or mock)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-test-key-for-integration-tests
# Set to 'mock' to use MSW mocks instead of real API
TEST_AI_MODE=mock

# =============================================================================
# Test Encryption & Security
# =============================================================================
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
COOKIE_SECRET=test-cookie-secret-for-oauth-state

# =============================================================================
# Test OAuth (use test apps or mocks)
# =============================================================================
TWITTER_CLIENT_ID=test-twitter-id
TWITTER_CLIENT_SECRET=test-twitter-secret

LINKEDIN_CLIENT_ID=test-linkedin-id
LINKEDIN_CLIENT_SECRET=test-linkedin-secret

FACEBOOK_APP_ID=test-facebook-id
FACEBOOK_APP_SECRET=test-facebook-secret

NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Test Queue (optional - tests will skip if not configured)
# =============================================================================
# QSTASH_TOKEN=test-token
# QSTASH_CURRENT_SIGNING_KEY=test-sig-key
# QSTASH_PROCESS_URL=http://localhost:3000/api/generate-posts/process

# =============================================================================
# Test Rate Limiting (uses memory by default)
# =============================================================================
RATE_LIMIT_MODE=memory

# =============================================================================
# Test Node Environment
# =============================================================================
NODE_ENV=test
