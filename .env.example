# PostRail Environment Variables
# Copy to .env.local and fill in your values
#
# ⚠️  PRODUCTION DEPLOYMENT CHECKLIST:
# - All REQUIRED variables must be set
# - CRITICAL variables will cause app to fail if missing
# - RECOMMENDED variables should be set for production (fallback to unsafe defaults)

# =============================================================================
# 🔴 CRITICAL - App won't start without these
# =============================================================================

# Supabase - https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # Required for billing, trial tracking

# Anthropic Claude AI - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# Encryption key for OAuth tokens (64 hex chars = 32 bytes AES-256)
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-64-char-hex-key

# 🔑 OAuth state signing (REQUIRED for production)
# Generate with: openssl rand -base64 32
# WARNING: Missing this in production allows OAuth CSRF attacks!
COOKIE_SECRET=your-random-secret-key

# =============================================================================
# SOCIAL PLATFORM OAUTH (Required for posting)
# =============================================================================

# Twitter/X - https://developer.twitter.com/en/portal/dashboard
TWITTER_CLIENT_ID=your-client-id
TWITTER_CLIENT_SECRET=your-client-secret

# LinkedIn - https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your-client-id
LINKEDIN_CLIENT_SECRET=your-client-secret

# Facebook - https://developers.facebook.com/apps
FACEBOOK_APP_ID=your-app-id
FACEBOOK_APP_SECRET=your-app-secret

# App URL for OAuth callbacks
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# 🟡 RECOMMENDED - Required for production features
# =============================================================================

# Post Scheduling - QStash (app throws error in production if missing)
# https://console.upstash.com/qstash
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...
QSTASH_PROCESS_URL=https://your-domain.com/api/generate-posts/process

# Rate Limiting - Redis (falls back to unsafe memory-only if missing)
# https://console.upstash.com/redis
# ⚠️  PRODUCTION: Memory fallback can be bypassed with multiple instances!
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# =============================================================================
# 🟢 OPTIONAL - Nice to have
# =============================================================================

# Sentry - https://sentry.io/
# SENTRY_DSN=https://...@sentry.io/...
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ORG=your-org
# SENTRY_PROJECT=postrail

# Email notifications (Resend) - https://resend.com/
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=PostRail <noreply@your-domain.com>

# Middleware configuration
# SUPABASE_AUTH_MIDDLEWARE_ENABLED=true  # Set if using middleware for session refresh

# =============================================================================
# OPTIONAL - Billing (Stripe)
# =============================================================================
# For self-hosted/open source deployments, billing is DISABLED by default.
# All users get unlimited "growth" tier access (all features, no limits).
#
# To enable billing/trial limits, set:
# BILLING_ENABLED=true

# Stripe - https://dashboard.stripe.com/apikeys
# Only needed if BILLING_ENABLED=true
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price IDs (create products in Stripe Dashboard)
# Standard tier: $29/month
# STRIPE_PRICE_STANDARD=price_...
# Growth tier: $59/month
# STRIPE_PRICE_GROWTH=price_...

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

NODE_ENV=development
RATE_LIMIT_MODE=memory
